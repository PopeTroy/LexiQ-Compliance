<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Real-time Grammarly Ingestion Status Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:background="#1E1E1E"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/suggestionText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="LexiQ: Scanning input text stream..."
            android:textColor="#00E676"
            android:textStyle="bold"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Basic Keyboard row simulation for layout container -->
    <android.inputmethodservice.KeyboardView
        android:id="@+id/keyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:keyBackground="@android:drawable/btn_default"
        android:background="#121212" />
</LinearLayout>
